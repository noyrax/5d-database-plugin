# Noyrax 5D Database Plugin — environment configuration
# Copy to .env and fill in. NEVER commit the real .env.

# Embeddings provider for the V-dimension (semantic search). Voyage AI is the default.
VOYAGE_API_KEY=

# Optional: OpenAI (alternative embeddings / module summaries)
OPENAI_API_KEY=

# Optional: Anthropic (ADR generation)
ANTHROPIC_API_KEY=
